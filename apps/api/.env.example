NODE_ENV=development
PORT=3001

# MongoDB
MONGODB_URI=mongodb://localhost:27017/gamehub

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Admin credentials (bcrypt hash of your password)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$10$changeme
ADMIN_SESSION_SECRET=change-me-to-a-random-64-char-string

# Cloudflare R2
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=gamehub
R2_PUBLIC_BASE_URL=https://your-bucket.r2.dev

# CORS: allow admin web origin
ADMIN_ORIGIN=http://localhost:5173
