{
  "name": "@gamehub/worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format cjs --out-dir dist --no-splitting",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@gamehub/r2-client": "workspace:*",
    "@gamehub/shared": "workspace:*",
    "bullmq": "^5.7.8",
    "dotenv": "^17.4.2",
    "ioredis": "^5.3.2",
    "mongoose": "^8.3.4"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "tsup": "^8.0.2",
    "tsx": "^4.10.5",
    "typescript": "^5.4.5"
  }
}
