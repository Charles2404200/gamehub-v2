{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "types": ["vite/client"],
    "paths": {
      "@gamehub/shared": ["../../packages/shared/src/index.ts"],
      "@/*": ["./src/renderer/src/*"]
    }
  },
  "include": ["src/renderer/vite-env.d.ts", "src/renderer/**/*.ts", "src/renderer/**/*.tsx"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
